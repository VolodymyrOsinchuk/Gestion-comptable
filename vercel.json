{
  "version": 2,
  "builds": [
    {
      "src": "server/api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/config/**",
          "server/models/**",
          "server/routes/**",
          "server/.env.production"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server/api/index.js"
    }
  ]
}
